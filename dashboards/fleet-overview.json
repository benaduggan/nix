{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage — $instance",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 0
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\", instance=\"$instance\"}[5m]))",
          "legendFormat": "cpu"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "title": "Memory Usage — $instance",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "node_memory_MemTotal_bytes{instance=\"$instance\"} - node_memory_MemAvailable_bytes{instance=\"$instance\"}",
          "legendFormat": "used"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "node_memory_MemTotal_bytes{instance=\"$instance\"}",
          "legendFormat": "total"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "title": "Memory % — $instance",
      "type": "gauge",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.85
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "1 - (node_memory_MemAvailable_bytes{instance=\"$instance\"} / node_memory_MemTotal_bytes{instance=\"$instance\"})",
          "legendFormat": "{{ instance }}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Disk Usage — $instance",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 21
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\", instance=\"$instance\"} - node_filesystem_avail_bytes{mountpoint=\"/\", instance=\"$instance\"}",
          "legendFormat": "used"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\", instance=\"$instance\"}",
          "legendFormat": "total"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "title": "Disk % — $instance",
      "type": "gauge",
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 29
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.7
              },
              {
                "color": "red",
                "value": 0.85
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\", instance=\"$instance\"} / node_filesystem_size_bytes{mountpoint=\"/\", instance=\"$instance\"})",
          "legendFormat": "{{ instance }}"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Network RX — $instance",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 34
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|br.*|docker.*\", instance=\"$instance\"}[5m])",
          "legendFormat": "{{ device }} rx"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "title": "Network TX — $instance",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 42
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|br.*|docker.*\", instance=\"$instance\"}[5m])",
          "legendFormat": "{{ device }} tx"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "title": "System Load (1m) — $instance",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 50
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "node_load1{instance=\"$instance\"}",
          "legendFormat": "load1"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "title": "Uptime — $instance",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 58
      },
      "repeat": "instance",
      "repeatDirection": "h",
      "maxPerRow": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 3600
              },
              {
                "color": "green",
                "value": 86400
              }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": ""
          },
          "expr": "time() - node_boot_time_seconds{instance=\"$instance\"}",
          "legendFormat": "uptime"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["fleet", "nodes"],
  "templating": {
    "list": [
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": ""
        },
        "query": "label_values(node_uname_info, instance)",
        "regex": "/^[^:]+$/",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": ["All"],
          "value": ["$__all"]
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "Fleet Overview",
  "uid": "fleet-overview"
}
