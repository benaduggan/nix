{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage by Host",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "1 - avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m]))",
          "legendFormat": "{{ instance }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Memory Usage by Host",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes",
          "legendFormat": "{{ instance }} used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "node_memory_MemTotal_bytes",
          "legendFormat": "{{ instance }} total"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Memory Usage % by Host",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{ instance }}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Disk Usage by Host",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\"} - node_filesystem_avail_bytes{mountpoint=\"/\"}",
          "legendFormat": "{{ instance }} used"
        },
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "node_filesystem_size_bytes{mountpoint=\"/\"}",
          "legendFormat": "{{ instance }} total"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Disk Usage % by Host",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 30 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})",
          "legendFormat": "{{ instance }}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      }
    },
    {
      "title": "Network Received by Host",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|veth.*|br.*|docker.*\"}[5m])",
          "legendFormat": "{{ instance }} {{ device }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Network Transmitted by Host",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|br.*|docker.*\"}[5m])",
          "legendFormat": "{{ instance }} {{ device }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "System Load (1m) by Host",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 44 },
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "node_load1",
          "legendFormat": "{{ instance }}"
        }
      ],
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Uptime by Host",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 52 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "green", "value": 86400 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "" },
          "expr": "time() - node_boot_time_seconds",
          "legendFormat": "{{ instance }}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["fleet", "nodes"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Fleet Overview",
  "uid": "fleet-overview"
}
